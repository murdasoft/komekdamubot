# ============================================
# KOMEK DAMU Bot — переменные окружения
# Скопируйте: cp .env.example .env
# Прод: Vercel → Project → Settings → Environment Variables
# ============================================

# --- Деплой (обязательно на Vercel) ---
# Публичный URL бота (webhook'и Telegram и WhatsApp)
WEBHOOK_BASE_URL=https://komek-damu-bot.vercel.app

# --- AI: together | groq | local ---
# Прод на Vercel: together + TOGETHER_API_KEY
AI_PROVIDER=together

# Together AI — основной LLM + STT на Vercel
# Ключ: https://api.together.xyz/settings/api-keys
# API:  https://api.together.xyz/v1
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo
TOGETHER_STT_MODEL=openai/whisper-large-v3

# Groq — резерв (free ~50 msg/day). На проде держать выключенным.
GROQ_ENABLED=false
# Ключ: https://console.groq.com/keys
# API:  https://api.groq.com/openai/v1
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_STT_MODEL=whisper-large-v3

# Google Gemini — аварийный fallback в коде (если Together/Groq упали)
# Ключ: https://aistudio.google.com/apikey
# API:  https://generativelanguage.googleapis.com
GOOGLE_API_KEY=

# Локальный AI (Ollama + faster-whisper на Hetzner/VPS)
# AI_PROVIDER=local
LOCAL_LLM_BASE_URL=
LOCAL_LLM_MODEL=qwen2.5:3b
LOCAL_LLM_API_KEY=
LOCAL_WHISPER_URL=
LOCAL_LLM_MAX_TOKENS=256
LOCAL_LLM_NUM_CTX=2048
LOCAL_LLM_KEEP_ALIVE=30m

# FAQ без нейронки (быстрые ответы из базы знаний)
FAST_FAQ=true

# --- Telegram ---
# Токен: @BotFather → /newbot
# API:   https://api.telegram.org/bot<TOKEN>/
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALERT_CHAT_ID=

# --- WhatsApp (Green API) ---
# Личный кабинет: https://console.green-api.com/
# Документация:  https://green-api.com/docs/
# API инстанса:  https://7107.api.greenapi.com  (номер региона = первые 4 цифры instance id)
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=
GREEN_API_URL=https://7107.api.greenapi.com
GREEN_API_WEBHOOK_TOKEN=

# --- Supabase (клиенты, сессии, сообщения, лиды) ---
# Dashboard: https://supabase.com/dashboard/project/ffjurwqeyezxaslhczxv
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Имена из Next.js / komek-проекта (бот подхватит автоматически):
# NEXT_PUBLIC_komek_SUPABASE_URL=
# NEXT_PUBLIC_komek_SUPABASE_ANON_KEY=
# komek_SUPABASE_SERVICE_ROLE_KEY=
# Миграция: python scripts/apply_supabase_schema.py (нужен komek_POSTGRES_URL_NON_POOLING)

# --- Bitrix24 (опционально, лиды в CRM) ---
BITRIX24_WEBHOOK_URL=

# --- Безопасность ---
# Chat ID через запятую, которые бот игнорирует
IGNORED_CHAT_IDS=

# --- Таймеры (секунды / часы) ---
REMINDER_DELAY_SECONDS=3600
ORDER_ABANDON_NUDGE_SECONDS=1800
HANDOFF_TIMEOUT_HOURS=24

# --- Только для локального деплоя (не нужно на Vercel) ---
# GITHUB_TOKEN=

# --- Только на VPS/Hetzner (скрипты whisper-api, не бот) ---
# WHISPER_MODEL=small
