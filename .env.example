# ============================================
# KOMEK DAMU Bot - Environment Configuration
# ============================================

# --- AI: together (Vercel) | groq | local ---
AI_PROVIDER=together
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo
TOGETHER_STT_MODEL=openai/whisper-large-v3

# --- Локальный AI (Ollama + faster-whisper) — Hetzner ---
# AI_PROVIDER=local
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434
# Рекомендуемые модели на 8GB RAM (ollama pull ...):
#   qwen2.5:3b          — быстрее, ru+kk ок
#   t-tech/t-lite-it-2.1:q4_K_M — лучший русский (~5GB)
#   llama3.2:3b         — стабильный чат
LOCAL_LLM_MODEL=qwen2.5:3b
LOCAL_WHISPER_URL=http://127.0.0.1:11435
LOCAL_LLM_API_KEY=ollama
FAST_FAQ=true
LOCAL_LLM_MAX_TOKENS=256
LOCAL_LLM_NUM_CTX=2048
LOCAL_LLM_KEEP_ALIVE=30m

# --- Groq (выключен: лимит ~50 сообщений/день). Включить: GROQ_ENABLED=true ---
GROQ_ENABLED=false
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_STT_MODEL=whisper-large-v3

# --- Telegram Bot (Optional) ---
# Get token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret
TELEGRAM_ALERT_CHAT_ID=your_telegram_chat_id_for_alerts

# --- WhatsApp Green API (Optional) ---
# Get credentials: https://green-api.com/
GREEN_API_INSTANCE_ID=your_instance_id
GREEN_API_TOKEN=your_green_api_token
GREEN_API_WEBHOOK_TOKEN=your_webhook_token

# --- Bitrix24 Integration (Optional) ---
BITRIX24_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/xx/xxxxxx/

# --- Webhook Base URL (Required for production) ---
# Example: https://your-project.vercel.app
WEBHOOK_BASE_URL=https://your-project.vercel.app

# --- Security ---
# Comma-separated list of chat IDs to ignore
IGNORED_CHAT_IDS=

# --- Timing Configuration ---
REMINDER_DELAY_SECONDS=3600
ORDER_ABANDON_NUDGE_SECONDS=1800
HANDOFF_TIMEOUT_HOURS=24

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
FAST_FAQ=true
