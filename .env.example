# ============================================
# KOMEK DAMU Bot — переменные окружения
# Скопируйте: cp .env.example .env
# Прод: Vercel → Project → Settings → Environment Variables
# ============================================

# --- Деплой (обязательно на Vercel) ---
# Публичный URL бота (webhook'и Telegram и WhatsApp)
WEBHOOK_BASE_URL=https://komek-damu-bot.vercel.app

# --- AI: together | groq | local ---
# Прод: Together (чат + STT), kk — приоритет
AI_PROVIDER=together

# Groq — основной LLM + STT (OpenAI-compatible)
# Ключ: https://console.groq.com/keys
# API:  https://api.groq.com/openai/v1
GROQ_API_KEY=
GROQ_ENABLED=true
GROQ_MODEL=openai/gpt-oss-120b
GROQ_STT_MODEL=whisper-large-v3

# Голос STT: together | groq | ensemble (Together+Groq параллельно, қазақша первым)
VOICE_STT_PROVIDER=ensemble
STT_LLM_REFINE=true
GROQ_VOICE_STT=false
GROQ_VOICE_INTENT=true
GROQ_VOICE_INTENT_MODEL=llama-3.1-8b-instant

# Together AI — основной LLM + Whisper STT
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo
TOGETHER_STT_MODEL=openai/whisper-large-v3

# Hugging Face — казахские Whisper (abilmansplus/whisper-turbo-kaz-rus-v1, …)
# Ключ: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=
HF_STT_ENABLED=true
HF_STT_MODEL=abilmansplus/whisper-turbo-kaz-rus-v1

# Google Gemini — аварийный fallback в коде (если Groq упал)
# Ключ: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Локальный AI (Ollama + faster-whisper на Hetzner/VPS)
# AI_PROVIDER=local
LOCAL_LLM_BASE_URL=
LOCAL_LLM_MODEL=qwen2.5:3b
LOCAL_LLM_API_KEY=
LOCAL_WHISPER_URL=
LOCAL_LLM_MAX_TOKENS=512
LOCAL_LLM_NUM_CTX=2048
LOCAL_LLM_KEEP_ALIVE=30m

# FAQ без нейронки (быстрые ответы из базы знаний)
FAST_FAQ=true

# Умный гид к FAQ (короткий вопрос вместо свободного чата), LLM — если правила не хватило
FAQ_GUIDE_LLM=true

# Гибрид: меню 1–7 + AI-агент (FAQ → LLM → гид)
HYBRID_AI=true

# --- Telegram ---
# Токен: @BotFather → /newbot
# API:   https://api.telegram.org/bot<TOKEN>/
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=changeme
TELEGRAM_ALERT_CHAT_ID=

# --- WhatsApp (Green API) ---
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=
GREEN_API_URL=https://7107.api.greenapi.com
GREEN_API_WEBHOOK_TOKEN=changeme

# --- Vercel Blob (казахские корпуса ~5 MB, private) ---
# Токен: Vercel → Storage → komek-damu-bot-blob → Settings
BLOB_READ_WRITE_TOKEN=
BLOB_STORE_ID=store_OTuiNVlUkxdaNaAx
BLOB_BASE_URL=https://otuinvlukxdanaax.private.blob.vercel-storage.com
KK_CORPUS_USE_BLOB=true

# --- Supabase (сессии, контекст, лиды) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Альтернативные имена (Vercel Supabase integration):
# komek_SUPABASE_URL / NEXT_PUBLIC_komek_SUPABASE_URL
# komek_SUPABASE_SERVICE_ROLE_KEY

# --- Bitrix24 (опционально) ---
BITRIX24_WEBHOOK_URL=

# --- Расписание чат-бота (Asia/Almaty) ---
# Будни 09:00–18:00 — автоответ выключен (менеджер). Вечер, сб–вс, праздники — бот.
BOT_SCHEDULE_ENABLED=false
BOT_TIMEZONE=Asia/Almaty
BOT_HUMAN_HOURS_START=09:00
BOT_HUMAN_HOURS_END=18:00
# Доп. праздники YYYY-MM-DD через запятую (к встроенному списку РК)
# BOT_HOLIDAYS=2026-05-25

# --- Прочее ---
IGNORED_CHAT_IDS=
REMINDER_DELAY_SECONDS=3600
ORDER_ABANDON_NUDGE_SECONDS=1800
HANDOFF_TIMEOUT_HOURS=24
